{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Information about the authenticated user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user first logged in" }
      },
      "required": ["uid", "email"]
    },
    "projects": {
      "title": "Project",
      "description": "Floor plan project data",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner UID" },
        "name": { "type": "string", "description": "Project name" },
        "data": { "type": "string", "description": "JSON string of the project state" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp" }
      },
      "required": ["userId", "name", "data"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile document"
    },
    "/projects/{projectId}": {
      "schema": "projects",
      "description": "Project document"
    }
  }
}
